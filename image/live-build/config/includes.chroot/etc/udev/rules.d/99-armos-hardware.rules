# armOS Hardware Detection Rules
# Feetech CH340/CH341 servo controllers
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", MODE="0666", GROUP="dialout", TAG+="armos"

# Dynamixel USB2Dynamixel / U2D2 (FTDI)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", MODE="0666", GROUP="dialout", TAG+="armos"
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", MODE="0666", GROUP="dialout", TAG+="armos"
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6015", MODE="0666", GROUP="dialout", TAG+="armos"

# Robotis U2D2
SUBSYSTEM=="tty", ATTRS{idVendor}=="fff1", ATTRS{idProduct}=="ff48", MODE="0666", GROUP="dialout", TAG+="armos"

# USB cameras (for reference — V4L2 handles these automatically)
SUBSYSTEM=="video4linux", TAG+="armos"
